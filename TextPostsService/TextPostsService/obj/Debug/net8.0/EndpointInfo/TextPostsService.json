{
  "openapi": "3.0.4",
  "info": {
    "title": "PostsAPI",
    "description": "API от микросервиса постов",
    "contact": {
      "name": "Ruslan",
      "url": "https://github.com/userchic"
    },
    "version": "v1"
  },
  "paths": {
    "/TextPost/CreatePost": {
      "post": {
        "tags": [
          "TextPost"
        ],
        "summary": "Запрос на создание поста",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "JWT токен",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "MyAuth",
            "in": "header",
            "description": "JWT токен2",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "Текст нового поста",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePostRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePostRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePostRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Возвращает только этот код"
          }
        }
      }
    },
    "/TextPost/UpdatePost": {
      "put": {
        "tags": [
          "TextPost"
        ],
        "summary": "Запрос на изменение поста",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "JWT токен",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "MyAuth",
            "in": "header",
            "description": "JWT токен2",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "Измененный пост с идентификатором",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePostRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePostRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/UpdatePostRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Возвращает только этот код"
          }
        }
      }
    },
    "/TextPost/DeletePost": {
      "delete": {
        "tags": [
          "TextPost"
        ],
        "summary": "Запрос на удаление поста",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "Идентификатор удаляемого поста",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "JWT токен",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "MyAuth",
            "in": "header",
            "description": "JWT токен2",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Возвращает только этот код"
          }
        }
      }
    },
    "/TextPost/GetPost": {
      "get": {
        "tags": [
          "TextPost"
        ],
        "summary": "Запрос на получение поста по идентификатору",
        "parameters": [
          {
            "name": "id",
            "in": "query",
            "description": "идентификатор поста",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "JWT токен",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "MyAuth",
            "in": "header",
            "description": "JWT токен2",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Возвращает только этот код"
          }
        }
      }
    },
    "/TextPost/GetUserPostsPage": {
      "get": {
        "tags": [
          "TextPost"
        ],
        "summary": "Запрос на получение страницы(10) постов указанного пользователя",
        "parameters": [
          {
            "name": "page",
            "in": "query",
            "description": "Номер страницы",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "userId",
            "in": "query",
            "description": "идентификатор владельца постов",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "JWT токен",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "MyAuth",
            "in": "header",
            "description": "JWT токен2",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Возвращает только этот код"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "CreatePostRequest": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UpdatePostRequest": {
        "type": "object",
        "properties": {
          "text": {
            "type": "string",
            "nullable": true
          },
          "id": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "TextPost"
    }
  ]
}