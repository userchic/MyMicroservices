{
  "openapi": "3.0.4",
  "info": {
    "title": "PostsAPI",
    "description": "API от микросервиса постов",
    "contact": {
      "name": "Ruslan",
      "url": "https://github.com/userchic"
    },
    "version": "v1"
  },
  "paths": {
    "/Consumer/StartConsuming": {
      "post": {
        "tags": [
          "Consumer"
        ],
        "summary": "Запрос на запуск консюмера читающего сообщения об опубликованных постах",
        "description": "Консюмер возможен только один и попытки создать еще не приведут ни к чему",
        "parameters": [
          {
            "name": "partition",
            "in": "query",
            "description": "Партиция из которой будет идти потребление",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "MyAuth",
            "in": "header",
            "description": "JWT токен",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/Consumer/StopConsuming": {
      "post": {
        "tags": [
          "Consumer"
        ],
        "summary": "Запрос на остановку работы консюмера",
        "description": "Консюмер возможен только один и попытки создать еще не приведут ни к чему. Консюмер выключится сразу, либо где-то за 10 секунд если он не может найти сообщения.",
        "parameters": [
          {
            "name": "MyAuth",
            "in": "header",
            "description": "JWT токен",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
