{
  "openapi": "3.0.4",
  "info": {
    "title": "User API",
    "description": "API от микросервиса пользователей",
    "contact": {
      "name": "Ruslan",
      "url": "https://github.com/userchic"
    },
    "version": "v1"
  },
  "paths": {
    "/User/Login": {
      "post": {
        "tags": [
          "User"
        ],
        "summary": "Выполняет вход в систему.",
        "description": "Возвращаемый токен надобно установить в куки. Но лучше в заголовок Authorization. \r\nПоскольку заголовок этот уничтожается прокси - предлагается использовать заголовок \"myauth\".",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "JWT токен",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "MyAuth",
            "in": "header",
            "description": "JWT токен2",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "Логин и пароль",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Возвращает только этот код"
          }
        }
      }
    },
    "/User/Register": {
      "post": {
        "tags": [
          "User"
        ],
        "summary": "Выполнит регистрацию в системе",
        "description": "Параметры валидируются\r\nВозвращаемый токен надобно установить в куки. Но лучше в заголовок Authorization. \r\nПоскольку заголовок этот уничтожается прокси - предлагается использовать заголовок \"myauth\".",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "JWT токен",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "MyAuth",
            "in": "header",
            "description": "JWT токен2",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "Логин, пароль, ФИО, Email и дата рождения",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegistryRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RegistryRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RegistryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Возвращает только этот код"
          }
        }
      }
    },
    "/User/GetProfile": {
      "get": {
        "tags": [
          "User"
        ],
        "summary": "Запрашивает профиль пользователя",
        "description": "Параметры валидируются",
        "parameters": [
          {
            "name": "login",
            "in": "query",
            "description": "Логин запрашиваемого пользователя",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "JWT токен",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "MyAuth",
            "in": "header",
            "description": "JWT токен2",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Возвращает только этот код"
          }
        }
      }
    },
    "/User/GetProfileById": {
      "get": {
        "tags": [
          "User"
        ],
        "summary": "Запрашивает профиль пользователя",
        "description": "Параметры валидируются",
        "parameters": [
          {
            "name": "userId",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "JWT токен",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "MyAuth",
            "in": "header",
            "description": "JWT токен2",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Возвращает только этот код"
          }
        }
      }
    },
    "/User/GetProfiles": {
      "get": {
        "tags": [
          "User"
        ],
        "summary": "Запрашивает профили пользователей, может выдать всех пользователей(нет пагинации).",
        "description": "Нет валидации, возвращается только список. Параметры не обязательны.",
        "parameters": [
          {
            "name": "login",
            "in": "query",
            "description": "Логин",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "name",
            "in": "query",
            "description": "Имя",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "surname",
            "in": "query",
            "description": "Фамилия",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "fatname",
            "in": "query",
            "description": "Отчество",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "Authorization",
            "in": "header",
            "description": "JWT токен",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "MyAuth",
            "in": "header",
            "description": "JWT токен2",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Возвращает только этот код"
          }
        }
      }
    },
    "/User/ChangeProfile": {
      "put": {
        "tags": [
          "User"
        ],
        "summary": "Выполняет редактирование профиля.",
        "description": "Здесь нужен Header myauth с токеном Bearer.",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "JWT токен",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "MyAuth",
            "in": "header",
            "description": "JWT токен2",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "description": "Логин, имя, фамилия, отчество, Email, дата рождения и Login с паролем измененного пользователя.",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangeProfileRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ChangeProfileRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ChangeProfileRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Возвращает только этот код"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChangeProfileRequest": {
        "type": "object",
        "properties": {
          "login": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "surname": {
            "type": "string",
            "nullable": true
          },
          "fatname": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "birthday": {
            "type": "string",
            "format": "date"
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "login": {
            "type": "string",
            "description": "Логин",
            "nullable": true
          },
          "password": {
            "type": "string",
            "description": "Пароль",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Контракт для запроса на вход в систему"
      },
      "RegistryRequest": {
        "type": "object",
        "properties": {
          "login": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          },
          "name": {
            "type": "string",
            "nullable": true
          },
          "surname": {
            "type": "string",
            "nullable": true
          },
          "fatname": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "birthday": {
            "type": "string",
            "format": "date"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "tags": [
    {
      "name": "User"
    }
  ]
}